# Knowfun.io API Configuration
# Copy this file to .env and fill in your values

# Your Knowfun.io API Key (get it from https://knowfun.io/api-platform)
KNOWFUN_API_KEY=kf_your_api_key_here

# Optional: Custom base URL (default: https://knowfun.io)
# KNOWFUN_BASE_URL=https://knowfun.io

# Optional: Request timeout in seconds (default: 300)
# KNOWFUN_TIMEOUT=300
